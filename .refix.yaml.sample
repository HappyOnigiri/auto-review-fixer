# ==========================================
# Refix Configuration File
# ==========================================

# Model settings (Optional)
# Specifies the models to use when executing the Claude CLI.
# Options: "haiku", "sonnet", "opus", etc.
models:
  summarize: "haiku"
  fix: "sonnet"

ci_log_max_lines: 120

# Whether to enable execution reports written by Claude (Optional)
# When enabled, runtime reports are embedded into the PR state comment
# and Claude receives instructions to append report entries to a report file.
# Default: false
execution_report: false

# Automatically merge PR when it reaches refix:done state (Optional)
# When merge completes, refix:merged label is added.
# Default: false
auto_merge: false

# Automatically post `@coderabbitai resume` when CodeRabbit can be resumed
# (after rate-limit wait expires or when a "Review failed" head-commit-changed status appears) (Optional)
# Default: false
coderabbit_auto_resume: false

# Maximum number of `@coderabbitai resume` comments posted in a single run (Optional, min: 1)
# The code enforces coderabbit_auto_resume_max_per_run >= 1.
# Default: 1
coderabbit_auto_resume_max_per_run: 1

# Whether to process DRAFT PRs (Optional)
# Default: false (skip DRAFT PRs)
process_draft_prs: false

# State comment timestamp timezone (Optional)
# Default: JST
# e.g. JST, UTC, Asia/Tokyo
state_comment_timezone: JST

# 1回の実行で変更を加えるPRの最大件数（0=無制限、Optional）
# ラベル付け替え、コメント投稿、state comment 更新などすべての変更を含む
# Default: 0
max_modified_prs_per_run: 0

# 1回の実行でコミットを追加するPRの最大件数（0=無制限、Optional）
# base branch マージ、CI修正、レビュー修正の push を含む
# Default: 2
max_committed_prs_per_run: 2

# 1回の実行でClaude修正を実行するPRの最大件数（0=無制限、Optional）
# CI修正、コンフリクト解消、レビュー修正を含む
# Default: 0
max_claude_prs_per_run: 0

# Target repository settings (Required)
# List the target repositories and their corresponding git commit settings.
repositories:
  - repo: "owner/repo"
