# Turso Cloud settings (leave unset to use local SQLite)
# REFIX_TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# REFIX_TURSO_AUTH_TOKEN=your-auth-token

# Claude models (default: haiku for summarization, sonnet for code fix)
# REFIX_MODEL_SUMMARIZE=haiku
# REFIX_MODEL_FIX=sonnet

# Target repositories (comma separated)
# - Single repo: owner/repo:user.name:user.email
# - All repos for owner/org: owner/*:user.name:user.email
# REPOS=octocat/Hello-World:Octocat:octocat@users.noreply.github.com
